{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://yjackgamestudio.dev/schemas/validation-evidence-packet.schema.json",
  "title": "Validation Evidence Packet Schema",
  "description": "Schema for autonomous validation evidence packets",
  "version": "1.0.0",
  "type": "object",
  "required": ["meta", "validation_context", "overall_verdict", "checks_run"],
  "properties": {
    "meta": {
      "type": "object",
      "required": ["packet_id", "validation_type", "timestamp", "agent"],
      "properties": {
        "packet_id": {
          "type": "string",
          "pattern": "^[a-z0-9-]+$"
        },
        "validation_type": {
          "type": "string"
        },
        "timestamp": {
          "type": "string",
          "format": "date-time"
        },
        "agent": {
          "type": "string"
        },
        "schema_version": {
          "type": "string",
          "default": "1.0"
        }
      }
    },
    "validation_context": {
      "type": "object",
      "required": ["target", "scope"],
      "properties": {
        "target": {
          "type": "string",
          "description": "What was validated"
        },
        "scope": {
          "type": "string",
          "description": "Scope of validation"
        },
        "trigger": {
          "type": "string"
        },
        "related_contracts": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "overall_verdict": {
      "type": "object",
      "required": ["status", "summary"],
      "properties": {
        "status": {
          "type": "string",
          "enum": ["PASS", "FAIL", "CONCERNS", "APPROVED", "BLOCKED", "COMPLETE", "READY", "COMPLIANT", "NON-COMPLIANT"]
        },
        "summary": {
          "type": "string",
          "minLength": 1
        },
        "confidence": {
          "type": "string",
          "enum": ["high", "medium", "low"]
        }
      }
    },
    "checks_run": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["check_name", "result"],
        "properties": {
          "check_name": {
            "type": "string"
          },
          "result": {
            "type": "string",
            "enum": ["PASS", "FAIL", "SKIP", "WARN"]
          },
          "detail": {
            "type": "string"
          },
          "output": {
            "type": "string"
          }
        }
      }
    },
    "issues_found": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["severity", "description"],
        "properties": {
          "severity": {
            "type": "string",
            "enum": ["critical", "major", "minor", "info"]
          },
          "description": {
            "type": "string"
          },
          "location": {
            "type": "string"
          },
          "remediation": {
            "type": "string"
          }
        }
      }
    },
    "manual_validation_required": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["item", "reason"],
        "properties": {
          "item": {
            "type": "string"
          },
          "reason": {
            "type": "string"
          },
          "validated_by": {
            "type": "string"
          },
          "validated_at": {
            "type": "string",
            "format": "date-time"
          }
        }
      }
    },
    "next_steps": {
      "type": "object",
      "properties": {
        "autonomous": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "requires_owner": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    }
  }
}
